# EcoSphere Environment Variables
# Copy this file to .env and configure your values

# Supabase configuration for client-side queries
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Note: The GROQ_API_KEY should NEVER be set in this client-side env file.
# Set it securely as a Supabase secret instead using:
# supabase secrets set GROQ_API_KEY=your_groq_api_key_here
